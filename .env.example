# ============================================================
# 4virtue chatbot_training - configuracao
# Copie este arquivo para .env (na pasta chatbot_training) e preencha.
# O .env real NAO deve ir pro git (ver .gitignore).
# ============================================================

# --- OpenRouter (obrigatorio) ---
# Pegue a chave em https://openrouter.ai/keys
OPENROUTER_API_KEY=cole_sua_chave_aqui

# Base da API (so mude se usar um proxy/gateway)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Modelos ---
# Modelo do AGENTE sob teste. PRECISA suportar tool calling (function calling).
# IDs validos no OpenRouter (ex.): anthropic/claude-sonnet-4.5, anthropic/claude-opus-4.8,
# openai/gpt-4o, google/gemini-2.5-flash. (anthropic/claude-3.5-sonnet foi descontinuado.)
AGENT_MODEL=anthropic/claude-sonnet-4.5

# Modelo do CLIENTE simulado (ICP). Pode ser mais barato.
# Ex.: openai/gpt-4o-mini, anthropic/claude-3.5-haiku, google/gemini-2.5-flash
ICP_MODEL=openai/gpt-4o-mini

# --- Parametros de simulacao ---
# Maximo de turnos do agente por conversa (1 turno = 1 mensagem do agente).
# Precisa de folga pra ir ate o fechamento (abertura > qualificacao > apresentacao > negociacao > fechamento).
MAX_TURNS=24
# Temperatura do agente e do ICP (0 a 1).
AGENT_TEMPERATURE=0.6
ICP_TEMPERATURE=0.8
# Teto de tokens de SAIDA por turno. Mensagens de WhatsApp sao curtas: manter baixo
# evita o erro 402 (modelos como opus reservam 65536 por padrao) e corta custo.
AGENT_MAX_TOKENS=4096
ICP_MAX_TOKENS=2048
# Maximo de chamadas de ferramenta encadeadas num MESMO turno do agente
# (nao confundir com MAX_TURNS). Se estourar, o agente e instruido a responder em texto.
AGENT_MAX_TOOL_ITERS=8

# Teto de custo (US$) por conversa. Ao ultrapassar, a conversa encerra com
# endReason 'budget_exceeded'. Use pra controlar o gasto do Opus. 0 = sem teto.
MAX_COST_PER_CONVERSATION=0.5

# --- Interface web ---
PORT=5173

# --- Metadados opcionais para o ranking do OpenRouter ---
OPENROUTER_APP_TITLE=4virtue-chatbot-training
OPENROUTER_SITE_URL=http://localhost
